# ==============================================================================
# EngageX Backend Environment Configuration Template
# ==============================================================================

# --- Groq API Keys ---
# API key used by the Groq Python SDK specifically for Whisper transcriptions
GROQ=your_groq_whisper_api_key_here
# API key used by LangChain (langchain-groq) for LLM routing and orchestration
GROQ_API_KEY=your_groq_llm_api_key_here

# --- HuggingFace ---
# Token for the HuggingFace Inference API used to generate BGE-M3 embeddings
HUGGINGFACEHUB_API_TOKEN=your_huggingface_token_here

# --- Pinecone Vector Database ---
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=engagex

# --- Upstash Redis (REST API for Session State & Caching) ---
UPSTASH_REDIS_REST_URL=https://your-database-name.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token_here

# --- Redis Server (Standard Protocol for RQ Job Queue) ---
REDIS_URL=redis://default:your_password@your-redis-host:6379

# --- Scraper Configurations (Optional Fallbacks) ---
# Instagram Credentials for Instaloader metadata extraction
IG_USERNAME=your_instagram_username_here
IG_PASSWORD=your_instagram_password_here

# yt-dlp Cookie Authentication for age-restricted or flagged videos
YTDLP_COOKIES_PATH=./youtube_cookies.txt
YTDLP_COOKIES_BROWSER=chrome